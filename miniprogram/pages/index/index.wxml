<!--miniprogram/pages/index/index.wxml-->
<!-- 桌面 -->
<image class="desktop desktop-{{bgCur+1}}" src="../../images/desktop/{{bgCur+1}}.png"></image>

<swiper class="index swiper" current="{{current}}" indicator-dots bindchange="swiperChange">
  <!-- Swiper1 -->
  <swiper-item class="swiper-item">
    <cu-custom></cu-custom>
    <view class="{{current === 0 ? 'animation-fade' : ''}}">
      <view class="margin-lr-lg margin-bottom-sm padding-lg text-grey bg-white radius">
        <view class="text-xsl text-center">{{clock}}</view>
        <view class="text-center">
          农历{{lunarDate}} {{week}}
        </view>
      </view>
      <view class="flex justify-between margin-lr-lg margin-top-sm">
        <view class="basis-df padding bg-white radius flex align-center justify-center shadow-wrap"
          bindtap="pageToDemo">
          <text class="cuIcon-mobilefill padding-xs bg-grey text-xl round"></text>
          <text class="margin-left-sm text-grey">小程序演示</text>
        </view>
        <view class="basis-df margin-left-sm">
          <view class="padding bg-white radius shadow-wrap" bindtap="pageToAbout">
            <text class="cuIcon-brand padding-xs bg-grey text-xl round"></text>
            <text class="margin-left-sm text-grey">关于小程序</text>
          </view>
          <view class="padding bg-white radius shadow-wrap margin-top-sm" bindtap="authorizeSetting">
            <text class="cuIcon-settingsfill padding-xs bg-grey text-xl round"></text>
            <text class="margin-left-sm text-grey">授权设置</text>
          </view>
        </view>
      </view>
    </view>
  </swiper-item>

  <!-- Swiper2 -->
  <swiper-item class="swiper-item">
    <cu-custom></cu-custom>
    <view class="margin">
      <!--drag组件外层需要适当加一定距离的margin, 防止某些情况精度计算误差导致drag宽度大于屏幕宽度, 从而出现横向滚动条-->
      <drag id="drag" generic:item="drag-item" list-data="{{list}}" columns="{{dragColumnsSize}}"
        radius="{{iconRadius}}" bind:click="itemClick" bind:change="change">
      </drag>
    </view>
  </swiper-item>
</swiper>