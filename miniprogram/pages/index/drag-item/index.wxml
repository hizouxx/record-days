<view catchtap="itemClick">
	<view class="flex flex-direction align-center">
		<view class="margin-lr-lg margin-top-lg padding-sm bg-gradual-{{itemData.color}} shadow-blur" style="border-radius: {{radius}}%">
			<view class="cuIcon-{{itemData.icon}} text-white text-sl"></view>
		</view>
		<text class="text-sm margin-top-sm">{{itemData.name}}</text>
	</view>
</view>