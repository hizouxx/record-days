/* miniprogram/pages/info/info.wxss */

.avatar-img {
  height: 100%;
  width: 100%;
}

.gender {
  position: absolute;
  right: 0;
  top: 0;
  width: 30rpx;
  height: 30rpx;
  padding: 2rpx;
}
.info-nav{
  height: 100rpx;
}

.info-con{
  position: relative;
  height: 150rpx;
}
.info-con-item{
  position: absolute;
  opacity: 0;
  z-index: 1;
  width: 690rpx;
}
.transition{
  opacity: 1;
  z-index: 2;
  transition: opacity 0.8s ease-in;
}